#RNAseqKIvsWT is the identifier for the respective enrichment created previously
RNAseqKIvsWT<- read_excel("path/to/your/file.xlsx")
>plot_RNAKIvsWT <- RNAseqKIvsWT[!is.na(RNAseqKIvsWT$GeneRatio), ]

#This is the code for dot plot generation
  
>ggplot(plot_RNAKIvsWT, aes(x = GeneRatio, y = reorder(GO_term, GeneRatio))) +
  geom_point(aes(size = Count, color = p.adjust)) +
  scale_color_gradient(low = "blue", high = "red", name = "p.adjust") +
  labs(title = "Enrichment Analysis",
       x = "Gene Ratio",
       y = "GO Term") +
  theme_minimal() +
  theme(
    panel.border = element_rect(color = "black", fill = NA, size = 1),
    axis.line = element_line(color = "black"),
    plot.title = element_text(size = 16, hjust = 0.5),
    axis.title.x = element_text(size = 14),
    axis.title.y = element_text(size = 14),
    legend.position = "right"
  )

